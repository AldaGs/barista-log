{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "slurrystats.vercel.app" }],
      "destination": "https://slurrystats.online/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/((?!api/|src/|assets/|node_modules/|@|.*\\.).*)", "destination": "/index.html" }
  ]
}
