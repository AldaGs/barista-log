# Supabase is OPTIONAL. The app works fully offline without it.
# Power users can also enter these values at runtime in Settings → Cloud sync,
# so you usually do NOT need this file. It only sets build-time defaults.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# OPTIONAL: short-link recipe sharing via the /api/share serverless function.
# Provision a Redis store (Vercel Marketplace → Upstash Redis, KV-compatible)
# and it injects these automatically. Without them, sharing falls back to
# self-contained fragment links — no backend required.
KV_REST_API_URL=
KV_REST_API_TOKEN=
